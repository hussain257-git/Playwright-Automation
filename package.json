{
  "name": "ecommerce-test-automation",
  "version": "1.0.0",
  "description": "Production-grade E-Commerce test automation framework using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test",
    "test:login": "playwright test --grep @login",
    "test:inventory": "playwright test --grep @inventory",
    "test:cart": "playwright test --grep @cart",
    "test:checkout": "playwright test --grep @checkout",
    "test:e2e": "playwright test --grep @e2e",
    "test:negative": "playwright test --grep @negative",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.saucedemo.com"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.19.39",
    "typescript": "^5.9.3"
  }
}
